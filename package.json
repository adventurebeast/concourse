{
  "name": "concourse",
  "version": "0.0.18",
  "description": "A stupidly simple IDE built for driving AI coding agents.",
  "main": "./out/main/index.js",
  "type": "module",
  "author": "adventurebeast",
  "license": "AGPL-3.0-only",
  "homepage": "https://github.com/adventurebeast/concourse#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/adventurebeast/concourse.git"
  },
  "bugs": {
    "url": "https://github.com/adventurebeast/concourse/issues"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "bump": "npm version patch --no-git-tag-version",
    "clean": "rm -rf out release",
    "fetch:llama": "node scripts/fetch-llama-server.mjs",
    "dist": "npm run fetch:llama && npm run bump && npm run clean && electron-vite build && electron-builder --mac",
    "pack": "npm run fetch:llama && npm run bump && npm run clean && electron-vite build && electron-builder --mac --dir",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{js,css,html}\"",
    "format:check": "prettier --check \"src/**/*.{js,css,html}\"",
    "postinstall": "electron-rebuild -f -w node-pty"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "latest",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^1.0.0",
    "simple-git": "^3.36.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "electron": "^33.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "monaco-editor": "^0.52.0",
    "prettier": "^3.8.4",
    "vite": "^5.4.0",
    "vitest": "^4.1.8"
  }
}
